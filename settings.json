{
  "editor.formatOnSave": true,
  "editor.suggest.insertMode": "replace",
  "window.zoomLevel": 2,
  "launch": {},
  "[json]": {},
  "editor.minimap.enabled": false,
  "breadcrumbs.enabled": false,
  "workbench.iconTheme": "material-icon-theme",
  "update.showReleaseNotes": false,
  "zenMode.hideLineNumbers": false,
  "editor.renderLineHighlight": "gutter",

  // "To improve performance": "",
  "extensions.experimental.affinity": {
    "vscodevim.vim": 1
  },
  "vim.leader": "<Space>",
  "vim.hlsearch": true,
  "vim.normalModeKeyBindingsNonRecursive": [
    { "before": ["<C-u>"], "after": ["<C-u>", "z", "z"] },
    { "before": ["<C-d>"], "after": ["<C-d>", "z", "z"] },

    { "before": ["leader", "w"], "commands": [":w!"] },
    { "before": ["leader", "c"], "commands": ["editor.action.commentLine"] },

    { "before": ["Y", "Y"], "commands": [":%y"] },
    { "before": ["<C-a>"], "after": ["G", "V", "g", "g"] },
    // change go to end of line ($) to 9 in vim mode
    {
      "before": ["L"],
      "after": ["$"],
      "command": "",
      "when": "editorTextFocus && vim.active && vim.use<C-r> && !inDebugRepl"
    },
    {
      "before": ["d", "L"],
      "after": ["d", "$"],
      "command": "",
      "when": "editorTextFocus && vim.active && vim.use<C-r> && !inDebugRepl"
    },
    {
      "before": ["c", "L"],
      "after": ["c", "$"],
      "command": "",
      "when": "editorTextFocus && vim.active && vim.use<C-r> && !inDebugRepl"
    },
    {
      "before": ["y", "L"],
      "after": ["y", "$"],
      "command": "",
      "when": "editorTextFocus && vim.active && vim.use<C-r> && !inDebugRepl"
    },
    {
      "before": ["v", "L"],
      "after": ["v", "$"],
      "command": "",
      "when": "editorTextFocus && vim.active && vim.use<C-r> && !inDebugRepl"
    },
    // change go to end of line ($) to 9 in vim mode
    {
      "before": ["H"],
      "after": ["_"],
      "command": "",
      "when": "editorTextFocus && vim.active && vim.use<C-r> && !inDebugRepl"
    },
    {
      "before": ["d", "H"],
      "after": ["d", "0"],
      "command": "",
      "when": "editorTextFocus && vim.active && vim.use<C-r> && !inDebugRepl"
    },
    {
      "before": ["c", "H"],
      "after": ["c", "0"],
      "command": "",
      "when": "editorTextFocus && vim.active && vim.use<C-r> && !inDebugRepl"
    },
    {
      "before": ["y", "H"],
      "after": ["y", "0"],
      "command": "",
      "when": "editorTextFocus && vim.active && vim.use<C-r> && !inDebugRepl"
    },
    {
      "before": ["v", "H"],
      "after": ["v", "0"],
      "command": "",
      "when": "editorTextFocus && vim.active && vim.use<C-r> && !inDebugRepl"
    },
    // // FILE TREE
    // {
    //   "before": ["leader", "n", "e"],
    //   "commands": ["workbench.explorer.fileView.focus"]
    // },
    // NAVIGATION
    // switch b/w buffers
    // splits
    { "before": ["leader", "v"], "commands": [":vsplit"] },
    { "before": ["leader", "s"], "commands": [":split"] },

    // panes
    {
      "before": ["<C-h>"],
      "commands": ["workbench.action.focusLeftGroup"]
    },
    {
      "before": ["leader", "j"],
      "commands": ["workbench.action.focusBelowGroup"]
    },
    {
      "before": ["leader", "k"],
      "commands": ["workbench.action.focusAboveGroup"]
    },
    {
      "before": ["<C-l>"],
      "commands": ["workbench.action.focusRightGroup"]
    }

    // NICE TO HAVE
    // {
    //   "before": ["[", "d"],
    //   "commands": ["editor.action.marker.prev"]
    // },
    // {
    //   "before": ["]", "d"],
    //   "commands": ["editor.action.marker.next"]
    // },
    // {
    // "before": ["<leader>", "c", "a"],
    //   "commands": ["editor.action.quickFix"]
    // },
    // { "before": ["leader", "f"], "commands": ["workbench.action.quickOpen"] }
    // { "before": ["leader", "p"], "commands": ["editor.action.formatDocument"] },
    // {
    //   "before": ["g", "h"],
    //   "commands": ["editor.action.showDefinitionPreviewHover"]
    // }
  ],

  "vim.visualModeKeyBindings": [
    // Stay in visual mode while indenting
    { "before": ["<C-u>"], "after": ["<C-u>", "z", "z"] },
    { "before": ["<C-d>"], "after": ["<C-d>", "z", "z"] },
    { "before": ["<"], "commands": ["editor.action.outdentLines"] },
    { "before": [">"], "commands": ["editor.action.indentLines"] },
    // Move selected lines while staying in visual mode
    { "before": ["J"], "commands": ["editor.action.moveLinesDownAction"] },
    { "before": ["K"], "commands": ["editor.action.moveLinesUpAction"] },
    // toggle comment selection
    { "before": ["leader", "c"], "commands": ["editor.action.commentLine"] }
  ],
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "editor.cursorBlinking": "solid",
  "workbench.activityBar.location": "hidden",
  "vim.useSystemClipboard": true,
  "editor.wordWrap": "off",
  "editor.cursorSurroundingLines": 7,
  "editor.scrollBeyondLastLine": true,
  "security.workspace.trust.untrustedFiles": "open",
  "workbench.statusBar.visible": false,
  "notebook.cellToolbarLocation": {
    "default": "right",
    "jupyter-notebook": "right"
  },
  "notebook.insertToolbarLocation": "betweenCells",
  "files.exclude": {
    "**/.venv/": true
  },
  "search.exclude": {
    "**.wav": true,
    "**.png": true,
    "**.zip": true,
    "**.svg": true,
    "**.pyc": true,
    "**.can": true,
    "**.mp4": true,
    "**.mp3": true,
    "**.pdf": true,
    "**.npy": true,
    "**.mdl": true,
    "**.pth": true,
    "**.onnx": true,
    "**.html": true,
    "**.pt": true,
    "**.csv": true,
    "**.run": true,
    "**.docx": true,
    // "**.md": true,
    // "**.txt": true,
    "**.pptx": true,
    "**.odp": true,
    "**.odg": true,
    "**.gif": true,
    "**.sdf": true,
    "**.smi": true,
    "**.exe": true,
    "**/Altfragen": true,
    "**/partial_exams": true,
    "**/.venv": true
  },
  "editor.fontSize": 14,

  // Serendipity
  // "editor.fontFamily": "'IBM Plex Mono', monospace",
  // "editor.lineHeight": 34,
  // "editor.letterSpacing": 0.5,
  // "files.trimTrailingWhitespace": true,
  // "editor.fontWeight": "normal",
  // "editor.cursorStyle": "line",
  // "editor.cursorWidth": 5,
  // "editor.renderWhitespace": "all",

  // other settings
  "vim.smartRelativeLine": true,
  "editor.lineNumbers": "relative",
  "notebook.globalToolbar": false,
  "notebook.showCellStatusBar": "hidden",
  "window.menuBarVisibility": "toggle",
  "notebook.scrolling.revealNextCellOnExecute": "firstLine",
  "workbench.colorTheme": "One Dark Pro",
  "notebook.lineNumbers": "on",
  "oneDarkPro.vivid": false,
  "workbench.startupEditor": "none",
  "github.copilot.editor.enableAutoCompletions": true
}
